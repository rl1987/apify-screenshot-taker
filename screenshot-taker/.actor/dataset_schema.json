{
    "$schema": "https://apify.com/schemas/v1/dataset.ide.json",
    "actorSpecification": 1,
    "fields": {},
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": ["url", "stealthEngine", "title", "screenshotUrl", "statusCode", "loadedAt", "error"]
            },
            "display": {
                "component": "table",
                "properties": {
                    "url": {
                        "label": "URL",
                        "format": "link"
                    },
                    "stealthEngine": {
                        "label": "Stealth engine",
                        "format": "text"
                    },
                    "title": {
                        "label": "Page title",
                        "format": "text"
                    },
                    "screenshotUrl": {
                        "label": "Screenshot",
                        "format": "image"
                    },
                    "statusCode": {
                        "label": "Status code",
                        "format": "number"
                    },
                    "loadedAt": {
                        "label": "Loaded at",
                        "format": "date"
                    },
                    "error": {
                        "label": "Error",
                        "format": "text"
                    }
                }
            }
        }
    }
}
